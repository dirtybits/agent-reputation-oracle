{
  "private": true,
  "license": "ISC",
  "workspaces": [
    "web",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:cli": "npm run build --workspace @agentvouch/cli",
    "build:web": "npm run build --workspace @agentvouch/web",
    "dev": "npm run dev --workspace @agentvouch/web",
    "dev:web": "npm run dev --workspace @agentvouch/web",
    "generate:client": "npm exec --workspace @agentvouch/web tsx ./scripts/generate-client.ts",
    "lint:web": "npm run lint --workspace @agentvouch/web",
    "lint:fix": "prettier \"**/*.{js,ts,tsx}\" -w",
    "lint:format": "prettier \"**/*.{js,ts,tsx}\" --check",
    "lint": "npm run lint:format && npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:cli": "npm run test --workspace @agentvouch/cli",
    "test:web": "npm run test --workspace @agentvouch/web"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "vercel": "^50.25.6"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
