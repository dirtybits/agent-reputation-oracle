{
  "private": true,
  "license": "ISC",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:cli": "npm --workspace @agentvouch/cli run build",
    "build:web": "npm --prefix web run build",
    "dev:web": "npm --prefix web run dev",
    "install:web": "npm --prefix web ci",
    "lint:fix": "prettier \"**/*.{js,ts,tsx}\" -w",
    "lint": "prettier \"**/*.{js,ts,tsx}\" --check",
    "test:cli": "npm --workspace @agentvouch/cli run test",
    "test:web": "npm --prefix web run test"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "vercel": "^50.25.6"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
}
